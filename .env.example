# ---- Supabase (Admin Panel + Forms) ----
# Supabase project → Settings → API se ye 2 values copy karo:
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Setup steps:
# 1. supabase.com par naya project banao
# 2. SQL Editor me pehle supabase/schema.sql run karo
# 3. Phir supabase/seed.sql run karo (website ka current data)
# 4. Is file ki copy banao naam: .env.local — upar ki 2 values bharo
# 5. Vercel par deploy karte waqt yahi 2 env vars add karna
# .env.local kabhi git me commit nahi hota (already .gitignore me hai).
